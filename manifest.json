{
  "manifest_version": 3,
  "name": "Danmaku Copilot",
  "version": "0.1.0",
  "description": "点击弹幕输入框后，AI 自动生成自然中文弹幕并填入草稿。",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://v.qq.com/*",
    "https://*.qq.com/*",
    "https://api.openai.com/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://v.qq.com/*"],
      "js": [
        "src/constants.js",
        "src/utils/dom.js",
        "src/utils/time.js",
        "src/content.js"
      ],
      "css": ["src/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "src/options.html",
  "action": {
    "default_title": "Danmaku Copilot",
    "default_popup": "src/popup.html"
  }
}
